generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ApplicationStatus {
  APPLIED
  SCREEN
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

model Application {
  id        String            @id @default(cuid())

  company   String
  roleTitle String
  jobUrl    String?
  location  String?
  status    ApplicationStatus @default(APPLIED)
  appliedAt DateTime          @default(now())

  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([company])
  @@index([status])
  @@index([appliedAt])
}