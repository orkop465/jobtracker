generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ApplicationStatus {
  APPLIED
  SCREEN
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

model Application {
  id        String            @id @default(cuid())
  company   String
  roleTitle String
  status    ApplicationStatus @default(APPLIED)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}